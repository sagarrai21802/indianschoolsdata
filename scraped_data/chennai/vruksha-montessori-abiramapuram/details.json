          }
        },
        {
          "@type": "Review",
          "itemReviewed": {
            "@type": "School",
            "name": "Vruksha Montessori - Abiramapuram"
          },
          "author": {
            "@type": "Person",
            "name": "V Sai S Narayana K"
          },
          "datePublished": "2019-04-03",
          "reviewRating": {
            "@type": "Rating",
            "ratingValue": "4",
            "bestRating": "5",
            "worstRating": "1"
          },
          "reviewBody": "This is  one of the best Montessori schools in the Abhirampuram  neighbourhood. The ambience is good. The management is very cooperative and ready to help. Kids grow up confidently in the montessori system. In this school the montessori system is followed upto 4th std. This school has been awarded best preschool of the year.The staff and the teachers are also very good,very patient and cooperative.Kids are encouraged to work independantly. The premises is reasonably big and can accommodate many students.",
          "publisher": {
            "@type": "Organization",
            "name": "Yellow Slate"
          }
        },
        {
          "@type": "Review",
          "itemReviewed": {
            "@type": "School",
            "name": "Vruksha Montessori - Abiramapuram"
          },
          "author": {
            "@type": "Person",
            "name": "vivek bharath"
          },
          "datePublished": "2018-11-28",
          "reviewRating": {
            "@type": "Rating",
            "ratingValue": "5",
            "bestRating": "5",
            "worstRating": "1"
          },
          "reviewBody": "Cant go wrong with this school. The negative reviews below makes me think if these guys are even real parents. My son studies here for the last 3 years  and i have to say we see  a happy kid waiting to go to school and comes back telling us he had so much fun. The school teaches habits and culture that is unbeatable in this age of schools.\n\nEvery kid is treated the same and no disability will stop these kids from treating each other as same. School teaches Diversity, respect to elders and most importantly teaching humility.",
          "publisher": {
            "@type": "Organization",
            "name": "Yellow Slate"
          }
        },
