          "reviewRating": {
            "@type": "Rating",
            "ratingValue": "5",
            "bestRating": "5",
            "worstRating": "1"
          },
          "reviewBody": "I'm glad that my ward is studying in this school. This is truly a 5D (5th Dimension) school that will help your children navigate towards the Sat Yug easily and effortlessly. If you wish more than just education for your kids, this is the place to be!\nThey sincerely give knowledge with love and compassion unconditionally.",
          "publisher": {
            "@type": "Organization",
            "name": "Yellow Slate"
          }
        },
        {
          "@type": "Review",
