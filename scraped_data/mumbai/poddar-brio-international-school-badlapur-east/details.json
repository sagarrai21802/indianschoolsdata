          "reviewRating": {
            "@type": "Rating",
            "ratingValue": "1",
            "bestRating": "5",
            "worstRating": "1"
          },
          "reviewBody": "Worst mangement. School is behind money, and not interested to give good education and services. We have paid fees but not at all happy. School timings are also affecting kids health. No hygiene in washrooms. Poor bus service. While taking admission they spoke every softly, after then they are not bother to listen parents concern. No professional teaching staff.",
          "publisher": {
            "@type": "Organization",
            "name": "Yellow Slate"
          }
        },
        {
