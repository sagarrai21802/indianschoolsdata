          "reviewRating": {
            "@type": "Rating",
            "ratingValue": "4",
            "bestRating": "5",
            "worstRating": "1"
          },
          "reviewBody": "This school is one of the prestigious institution in locality, More students are studying in this school and they serving the society for close to 30years now. All teachers are well qualified and friendly with students. After getting to this school my son discipline and academic standards got improved and he is talking to everyone without fear and he demonstrates punctuality everywhere now. School has lab, library, Indoor auditorium, Big ground, Kids play area, Garden area, Church, Canteen, CCTV, Big parking place, Transportation,  Pets Zone and many more. I am very satisfied of picking the right school now.",
          "publisher": {
            "@type": "Organization",
            "name": "Yellow Slate"
          }
        },
