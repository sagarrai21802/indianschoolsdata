          },
          "author": {
            "@type": "Person",
            "name": "Rakhi Jaggi"
          },
          "datePublished": "2024-02-12",
          "reviewRating": {
            "@type": "Rating",
            "ratingValue": "5",
            "bestRating": "5",
            "worstRating": "1"
          },
          "reviewBody": "It’s an outstanding experience for my daughter Vaanya Mangla from the moment she enrolled it has been evident that school prioritize not only academic excellence but holistic and nurturing development. The dedication and passion exhibited by teachers staff and would love to mention Anuradha mam (principal) have consistently exceeded my expectations. Moreover innovation, sense of comminity and the atmosphere where child feels empowered is truly remarkable . Thanks for exceptional place for learning\n\nParents - Anuj Mangla and Rakhi",
          "publisher": {
            "@type": "Organization",
            "name": "Yellow Slate"
          }
        },
