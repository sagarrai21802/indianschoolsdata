          "author": {
            "@type": "Person",
            "name": "Emma Watson"
          },
          "datePublished": "2022-10-30",
          "reviewRating": {
            "@type": "Rating",
            "ratingValue": "1",
            "bestRating": "5",
            "worstRating": "1"
          },
          "reviewBody": "Students are not getting proper education here, most of the teachers are not teaching properly and won’t listen to the students opinions. We have complained several times asking the management to take action but haven’t seen any changes at all. This is supposed to be a co-Ed school but boys are strictly prohibited from talking to girls. Portions are not being completed on time, proper revision is not being given and we have to pay for tuitions outside to learn everything. The new principal of the school doesn’t seem to respect students’ opinions and is not willing to listen our concerns. Completely disappointed with this school, it’s not like how it once was before.",
          "publisher": {
            "@type": "Organization",
            "name": "Yellow Slate"
          }
        }
