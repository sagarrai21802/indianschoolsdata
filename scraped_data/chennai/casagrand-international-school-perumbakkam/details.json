          },
          "datePublished": "2025-03-22",
          "reviewRating": {
            "@type": "Rating",
            "ratingValue": "5",
            "bestRating": "5",
            "worstRating": "1"
          },
          "reviewBody": "My son Ishanputhra (Class:6B) received tremendous support in his studies, and I am a proud and grateful mom! Sincere thanks to all the teachers, especially Muthu Meenakshi Ma’am and our exceptional principal, Sulochana Ma’am, for their dedication and guidance…\nCasagrand International School provides an international standard of education, ensuring excellence in learning and overall development.",
          "publisher": {
            "@type": "Organization",
            "name": "Yellow Slate"
          }
        },
