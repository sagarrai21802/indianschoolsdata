          "reviewRating": {
            "@type": "Rating",
            "ratingValue": "5",
            "bestRating": "5",
            "worstRating": "1"
          },
          "reviewBody": "Thanks to the management, principal and teachers for taking good care of children. Teachers are professional and well organized. Things are going in positive note as new principal took charge. Children are enjoying their schooling by learning new things daily. kudos to them.",
          "publisher": {
            "@type": "Organization",
            "name": "Yellow Slate"
          }
        },
        {
          "@type": "Review",
          "itemReviewed": {
            "@type": "School",
