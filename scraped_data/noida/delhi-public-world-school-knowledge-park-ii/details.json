          "reviewRating": {
            "@type": "Rating",
            "ratingValue": "5",
            "bestRating": "5",
            "worstRating": "1"
          },
          "reviewBody": "I have studied at Delhi World Public School, Greater Noida for 4 years and have had a wonderful experience. The faculty is good and co-operative. Teachers are always ready to help and specially the commerce teachers. Constant assistance in academics and co-curricular activities is provided with many inter school competitions. I got 95.2% in 12th. Thank you for a great 4 year experience ✨",
          "publisher": {
            "@type": "Organization",
            "name": "Yellow Slate"
          }
        },
