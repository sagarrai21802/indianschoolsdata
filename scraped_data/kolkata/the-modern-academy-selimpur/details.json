          },
          "datePublished": "2022-04-05",
          "reviewRating": {
            "@type": "Rating",
            "ratingValue": "5",
            "bestRating": "5",
            "worstRating": "1"
          },
          "reviewBody": "The best place to develop your child's future.. The teacher's are all excellent and give their 200% to teach the students. From junior to secondary and senior secondary all the teachers are just fabulous.. The teachers keep guiding the students until they become dedicated to their studies... The best place of childhood learning..love it.. 💓",
          "publisher": {
            "@type": "Organization",
            "name": "Yellow Slate"
          }
        },
