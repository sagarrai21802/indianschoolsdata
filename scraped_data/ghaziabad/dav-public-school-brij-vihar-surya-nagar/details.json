          "reviewRating": {
            "@type": "Rating",
            "ratingValue": "5",
            "bestRating": "5",
            "worstRating": "1"
          },
          "reviewBody": "D. A. V , Brij Vihar is the best in my opinion. I have it growing since beginning. Values inculcated in the veins of the students, were felt by me. My two children are the alumni of the school. One is working as the scientist head in America and another one is pursuing B. Tech from a very prestigious institute. The school provides the best platform for the all round development of the school and the best part is the new Principal of the school, who is working day and night for the new heights to be achieved by this prestigious institution.",
          "publisher": {
            "@type": "Organization",
            "name": "Yellow Slate"
          }
        },
        {
          "@type": "Review",
          "itemReviewed": {
            "@type": "School",
