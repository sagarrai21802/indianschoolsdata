          },
          "datePublished": "2022-09-17",
          "reviewRating": {
            "@type": "Rating",
            "ratingValue": "5",
            "bestRating": "5",
            "worstRating": "1"
          },
          "reviewBody": "I attended this school nearly 2 decades ago and have only great things to say about my experience. The teachers are amazing, the curriculum is second to none and each child is treated with care.  My daughter is attending this school as well and she loves her school and teachers. Amity integrates compassion into their teaching standards, emphasizes the importance of values, and builds leaders through each of their classes and lessons.",
          "publisher": {
            "@type": "Organization",
            "name": "Yellow Slate"
          }
        },
        {
          "@type": "Review",
