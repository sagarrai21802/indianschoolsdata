            "ratingValue": "5",
            "bestRating": "5",
            "worstRating": "1"
          },
          "reviewBody": "MRIS is an excellent school with all required facilities and able teachers as well as support staff for holistic development of the child. The students participate and compete in all kinds to educational and extra curriculum activities with other schools resulting in competitive attitude and leadership qualities. I am very happy with the performance of the school.",
          "publisher": {
            "@type": "Organization",
            "name": "Yellow Slate"
          }
        },
