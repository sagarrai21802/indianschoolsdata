          },
          "author": {
            "@type": "Person",
            "name": "Sayantani Ghosh"
          },
          "datePublished": "2023-04-26",
          "reviewRating": {
            "@type": "Rating",
            "ratingValue": "5",
            "bestRating": "5",
            "worstRating": "1"
          },
          "reviewBody": "This is an age old school which we know from our very childhood. My son visited there recently for a interschool fest called Ullas.\nThe school has an option for both morning as well as afternoon timings",
          "publisher": {
            "@type": "Organization",
            "name": "Yellow Slate"
          }
        },
        {
          "@type": "Review",
