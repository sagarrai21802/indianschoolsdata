          "reviewRating": {
            "@type": "Rating",
            "ratingValue": "5",
            "bestRating": "5",
            "worstRating": "1"
          },
          "reviewBody": "My daughter studies in MRIS, Sector - 14 Faridabad. She thrives in a nurturing environment that fosters learning, growth and creativity. Teachers exhibit remarkable proficiency, ensuring child’s needs are met. Grateful for their dedication to creating a supportive and enriching educational journey. Highly recommend this school for a holistic learning experience.",
          "publisher": {
            "@type": "Organization",
            "name": "Yellow Slate"
          }
        },
        {
          "@type": "Review",
          "itemReviewed": {
            "@type": "School",
            "name": "Manav Rachna International School - Sector 14"
          },
          "author": {
