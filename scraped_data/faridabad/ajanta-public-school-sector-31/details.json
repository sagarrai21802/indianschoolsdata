          "reviewRating": {
            "@type": "Rating",
            "ratingValue": "5",
            "bestRating": "5",
            "worstRating": "1"
          },
          "reviewBody": "This schoolis best school best infrastructure and best facilities and the teachers is also very supportive I like to thank you for greatly supporting my kid in his studies. I truly appreciate your patience to take care of my child at school through out the year. I am Glad that you help him grow well.\nThe school has been successful in striking an appropriate balance between Academic and Co-Curricular activities. Thank you so much for this level of support, truly appreciate that. Thank you so much Ajanta family",
          "publisher": {
            "@type": "Organization",
            "name": "Yellow Slate"
          }
        },
        {
          "@type": "Review",
          "itemReviewed": {
            "@type": "School",
