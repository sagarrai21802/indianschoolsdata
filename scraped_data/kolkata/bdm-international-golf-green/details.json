            "worstRating": "1"
          },
          "reviewBody": "It has been an amazing journey with BDMI. Being an alumni, and now a teacher....has been worth cherishing... Really happy with the growing infrastructure and the interactive learning process.",
          "publisher": {
            "@type": "Organization",
            "name": "Yellow Slate"
          }
        },
        {
          "@type": "Review",
          "itemReviewed": {
            "@type": "School",
