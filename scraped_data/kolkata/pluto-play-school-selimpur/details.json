          },
          "author": {
            "@type": "Person",
            "name": "Sudipto Chakraborty"
          },
          "datePublished": "2024-06-05",
          "reviewRating": {
            "@type": "Rating",
            "ratingValue": "5",
            "bestRating": "5",
            "worstRating": "1"
          },
          "reviewBody": "Our daughter Sunayana has been attending the summer camps during the last two years. She also attends the day care from time to time. We have found the team to be caring, responsive and to provide the kids with innovative activities to foster their all round development. Our daughter feels safe there which is why she enjoys herself during the activities and stays there for long durations. Hope the good work continues.",
          "publisher": {
            "@type": "Organization",
            "name": "Yellow Slate"
          }
