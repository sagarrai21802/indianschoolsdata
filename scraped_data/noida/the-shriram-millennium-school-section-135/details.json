          "reviewRating": {
            "@type": "Rating",
            "ratingValue": "5",
            "bestRating": "5",
            "worstRating": "1"
          },
          "reviewBody": "The best school in Noida following a complete child centric methodology. It's a 'happy school' for every individual who walks into the premises. Through various hands on activities in class, through music, dance, basketball , soccer..... in every domain the school believes giving exposure to the young minds to excel in their chosen fields.\nWith well trained academic staff at every level the school follows ICSE/ISC curriculum and is a leading name in NCR for its exemplary Board Examination results year after year.\nIt is a school with HEART.",
          "publisher": {
            "@type": "Organization",
            "name": "Yellow Slate"
          }
        },
        {
          "@type": "Review",
          "itemReviewed": {
            "@type": "School",
