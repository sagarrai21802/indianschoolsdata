          },
          "reviewBody": "Fantastic events! Co curricular activities, sports, music and speaking skills are all done along with education. Neat classrooms, and labs arranged with sort of things needed.",
          "publisher": {
            "@type": "Organization",
            "name": "Yellow Slate"
          }
        },
