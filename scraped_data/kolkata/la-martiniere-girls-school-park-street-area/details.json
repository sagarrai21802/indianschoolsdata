          "author": {
            "@type": "Person",
            "name": "DR VINEET NAIR"
          },
          "datePublished": "2020-06-13",
          "reviewRating": {
            "@type": "Rating",
            "ratingValue": "5",
            "bestRating": "5",
            "worstRating": "1"
          },
          "reviewBody": "Located at Minto Park, Rawdon St, Kolkata, West Bengal, La Martiniere for Girls is a heritage institution that has served the cause of education for 184 years, established in 1836 by Frenchman major general, Claude Martin. The school is affiliated with the Council for Indian School Certificate Examination and offers its class X ICSE and class XII ISC exams. The School provides the education with its best infrastructural facilities like a well-stocked library with age appropriate books, a computer lab and special teachers for sports, dance, art etc.",
          "publisher": {
            "@type": "Organization",
            "name": "Yellow Slate"
          }
        },
