          "reviewRating": {
            "@type": "Rating",
            "ratingValue": "4",
            "bestRating": "5",
            "worstRating": "1"
          },
          "reviewBody": "Sri Jugal Kishore Birla and Sri Ghanashyam Das Birla had a great role in setting up this school in 1920. It is an English medium, higher secondary and private school. It is run by a parent body 'Shikhshayatan Foundation '.  It is affiliated to the Central Board of Secondary Education. Here additional features are swimming pool, basketball, karate, canteen, computer etc. It has been acquired as a result of contesting the British Council International School Award many times. The outcome is satisfactory.",
          "publisher": {
            "@type": "Organization",
            "name": "Yellow Slate"
          }
        },
        {
          "@type": "Review",
          "itemReviewed": {
            "@type": "School",
