          "reviewRating": {
            "@type": "Rating",
            "ratingValue": "5",
            "bestRating": "5",
            "worstRating": "1"
          },
          "reviewBody": "We have never been a part of such a great school annual show before. Each and every student was full of confidence and enthusiasm to play their part on stage and the flow of the show from the very beginning to ending was so seamless. The costume, light, background complementing each other to a great extent. Once again hats off to all the mentors and students to put up such a mesmerizing show.",
          "publisher": {
            "@type": "Organization",
            "name": "Yellow Slate"
          }
        },
