          },
          "datePublished": "2022-03-07",
          "reviewRating": {
            "@type": "Rating",
            "ratingValue": "5",
            "bestRating": "5",
            "worstRating": "1"
          },
          "reviewBody": "I am happy to share my Experience with JKG International School Vijay Nagar branch. My daughter is studying in class 1st. She is very excited to go school every day and after come back from school she always expressed her good experience of class. Even In Lockdown period online classes was conducted in very proper manner and completed their curriculum on time. I want to say thanks to all teachers and administration who are very supportive.",
          "publisher": {
            "@type": "Organization",
            "name": "Yellow Slate"
          }
        },
