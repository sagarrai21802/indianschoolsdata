          "datePublished": "2024-03-04",
          "reviewRating": {
            "@type": "Rating",
            "ratingValue": "5",
            "bestRating": "5",
            "worstRating": "1"
          },
          "reviewBody": "As a parent, I always aspire to see my child Devanshi Ahuja to grow as an independent person. MRIS has been instrumental in achieving this growth. Since Toddlers till Grade 10 now, I have seen exponential skill development in her. Devanshi has a creative bent of mind, which is explored to its full potential here. MRIS is a platform of opportunities which ensures that every student participates, puts in efforts, and reaps the benefits of it. The school prioritizes a strong bond among teachers, students and parents.",
          "publisher": {
            "@type": "Organization",
            "name": "Yellow Slate"
          }
        },
        {
          "@type": "Review",
          "itemReviewed": {
            "@type": "School",
            "name": "Manav Rachna International School - Sector 14"
          },
          "author": {
            "@type": "Person",
