          },
          "datePublished": "2023-06-10",
          "reviewRating": {
            "@type": "Rating",
            "ratingValue": "0",
            "bestRating": "5",
            "worstRating": "1"
          },
          "reviewBody": "I visited the school to enquire regarding admission for my children. It is a start up IB school, located in Besant Nagar. I met the Principal and the CEO of the school. They explained in detail about IB curriculum, their vision for the school and how they can customize learning for children according to their needs. They emphasize on the need to make children future ready and tech savvy. They even have Robot buddies for children to interact and learn.",
          "publisher": {
            "@type": "Organization",
            "name": "Yellow Slate"
          }
        },
