          "reviewRating": {
            "@type": "Rating",
            "ratingValue": "5",
            "bestRating": "5",
            "worstRating": "1"
          },
          "reviewBody": "Brilliant School is an exceptional institution that offers an outstanding education experience. The faculty members are highly dedicated and skilled, creating a nurturing and stimulating learning environment. The school's curriculum is well-rounded, providing a strong foundation in academics, arts, and extracurricular activities. The facilities are top-notch, with modern classrooms and excellent resources. Overall, Brilliant School is a remarkable place that prepares students for success and fosters a love for learning. Highly recommended!",
          "publisher": {
            "@type": "Organization",
            "name": "Yellow Slate"
          }
        },
        {
          "@type": "Review",
          "itemReviewed": {
